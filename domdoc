<?php

namespace App\Http\Controllers;

use Illuminate\Http\Request;
use App\Models\ServerHistory;
use App\Models\ServerConfig;
use App\Models\CompareServerConfig;
use Illuminate\Support\Facades\Storage;
use Illuminate\Support\Facades\Response;

class GenerateXmlController extends Controller
{
    public function generate()
    {
        self::generateXml();

        return response()->download(
            storage_path('app/public/current.xml')
        );
    }

    public static function generateXml()
    {
        // Cek apakah ada perubahan
        $adaPerubahan = CompareServerConfig::where('xml_generated', false)->exists();

        if (!$adaPerubahan) {
            return true;
        }

        // Ambil semua data CompareServerConfig
        $servers = CompareServerConfig::orderBy('kode_pks')->get();

        $currentPath = storage_path('app/public/current.xml');
        $previousPath = storage_path('app/public/previous.xml');

        // Simpan current menjadi previous
        if (file_exists($currentPath)) {
            copy($currentPath, $previousPath);
        }

        //ini current
        $dom = new \DOMDocument('1.0', 'UTF-8');
        $dom->formatOutput = true;

        $xml = $dom->createElement('xml');

$xml->setAttribute(
    'xmlns:s',
    'uuid:BDC6E3F0-6DA3-11d1-A2A3-00AA00C14882'
);

$xml->setAttribute(
    'xmlns:dt',
    'uuid:C2F41010-65B3-11d1-A29F-00AA00C14882'
);

$xml->setAttribute(
    'xmlns:rs',
    'urn:schemas-microsoft-com:rowset'
);

$xml->setAttribute(
    'xmlns:z',
    '#RowsetSchema'
);

$dom->appendChild($xml);

//schema
$schema = $dom->createElement('s:Schema');
$schema->setAttribute('id', 'RowsetSchema');

$xml->appendChild($schema);

//element type
$elementType = $dom->createElement('s:ElementType');

$elementType->setAttribute('name', 'row');
$elementType->setAttribute('content', 'eltOnly');
$elementType->setAttribute('rs:updatable', 'true');

$schema->appendChild($elementType);

self::addAttribute($dom, $elementType, 'TRM_ID', 'string', 50);
self::addAttribute($dom, $elementType, 'TRM_USED', 'int', 4);
self::addAttribute($dom, $elementType, 'TRM_CODE', 'string', 50);
self::addAttribute($dom, $elementType, 'TRM_INIT', 'string', 50);
self::addAttribute($dom, $elementType, 'TRM_DESC', 'string', 50);
self::addAttribute($dom, $elementType, 'TRM_HOST', 'string', 50);
self::addAttribute($dom, $elementType, 'TRM_PORT', 'int', 4);
self::addAttribute($dom, $elementType, 'TRM_DB', 'string', 50);
self::addAttribute($dom, $elementType, 'TRM_USER', 'string', 50);
self::addAttribute($dom, $elementType, 'TRM_PASS', 'string', 50);
self::addAttribute($dom, $elementType, 'TRM_STS_PING', 'int', 4);
self::addAttribute($dom, $elementType, 'TRM_LAST_CHECKED', 'dateTime', 16);
self::addAttribute($dom, $elementType, 'TRM_LAST_UPDATED', 'dateTime', 16);

//data
$data = $dom->createElement('rs:data');

$insert = $dom->createElement('rs:insert');

$data->appendChild($insert);

$xml->appendChild($data);

//save
$dom->save($currentPath);


        // Tandai semua perubahan sudah digenerate
        CompareServerConfig::query()->update([
            'xml_generated' => true
        ]);

        return true;
    }

    private static function addAttribute($dom, $elementType, $name, $type, $maxLength)
{
    $attribute = $dom->createElement('s:AttributeType');
    $attribute->setAttribute('name', $name);
    $attribute->setAttribute('rs:number', '1');
    $attribute->setAttribute('rs:nullable', 'true');
    $attribute->setAttribute('rs:write', 'true');

    $datatype = $dom->createElement('s:datatype');
    $datatype->setAttribute('dt:type', $type);

    if ($type == 'string') {
        $datatype->setAttribute('rs:dbtype', 'str');
    }

    $datatype->setAttribute('dt:maxLength', $maxLength);
    $datatype->setAttribute('rs:precision', '0');

    $attribute->appendChild($datatype);

    $elementType->appendChild($attribute);
}


}
